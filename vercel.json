{
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/admin.html", "dest": "/admin.html" }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|admin|admin\\.html).*)",
      "destination": "/index.html"
    }
  ]
}
