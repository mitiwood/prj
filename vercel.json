{
  "rewrites": [
    { "source": "/admin",     "destination": "/admin.html"  },
    { "source": "/admin.html","destination": "/admin.html"  },
    { "source": "/api/:path*","destination": "/api/:path*"  },
    { "source": "/:path*",    "destination": "/index.html"  }
  ],
  "crons": [
    {
      "path": "/api/cron/status",
      "schedule": "*/30 * * * *"
    }
  ]
}
